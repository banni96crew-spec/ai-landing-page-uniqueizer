############################################
# APP — General Application Configuration
############################################

APP_NAME=ai-landing-page-uniqueizer
# Application name (example: ai-landing-page-uniqueizer)

APP_ENV=development
# Application environment: development | staging | production

APP_HOST=0.0.0.0
# Host interface for FastAPI (example: 0.0.0.0)

APP_PORT=8000
# Backend HTTP port (example: 8000)

FRONTEND_PORT=3000
# Next.js frontend port (example: 3000)

LOG_LEVEL=info
# Logging level: debug | info | warn | error (example: info)


############################################
# DATABASE — SQLite (MVP) Configuration
############################################

DATABASE_URL=backend/data/app.db
# Path to SQLite database file for local dev. Docker overrides it with /app/data/app.db.

SQLITE_BUSY_TIMEOUT_MS=10000
# SQLite busy timeout in milliseconds (example: 10000 ms)


############################################
# SECURITY & AUTH — CORS, SSRF Protection
############################################

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CSV list of allowed CORS origins (example: http://localhost:3000)

CORS_ALLOW_CREDENTIALS=true
# Whether to allow credentials in CORS (true/false)

BLOCK_PRIVATE_IP_RANGES=true
# Enable SSRF protection against private/reserved IP ranges (true/false)

ALLOWED_URL_SCHEMES=http,https
# Allowed schemes for target_url validation (CSV, example: http,https)


############################################
# WORKER — Concurrency & Pipeline Control
############################################

WORKER_POLL_INTERVAL=2
# Interval between DB polling cycles in seconds (example: 2 s)

WORKER_CONCURRENCY=2
# Max number of parallel jobs (recommended <=4 due to Playwright RAM usage)

JOB_TIMEOUT_SECONDS=600
# Global timeout for entire pipeline per job (example: 600 s)

MAX_QUEUE_SIZE=100
# Maximum number of jobs with status='pending' (example: 100)


############################################
# STORAGE — Artifacts & Work Directories
############################################

JOBS_WORKDIR=/app/volumes/jobs
# Base directory for temporary job working files

ARTIFACTS_DIR=/app/volumes/artifacts
# Directory where final ZIP artifacts are stored

ARTIFACT_TTL_DAYS=7
# Retention period for completed ZIP artifacts (example: 7 days)

FAILED_JOB_TTL_DAYS=7
# Retention period for failed job directories (example: 7 days)


############################################
# SCRAPER — Network & Asset Limits
############################################

SCRAPER_PAGE_TIMEOUT_SECONDS=60
# Timeout for Playwright page.goto() in seconds (example: 60 s)

ASSET_DOWNLOAD_TIMEOUT_SECONDS=15
# Timeout for single asset HTTP download in seconds (example: 15 s)

ASSET_MAX_SIZE_BYTES=52428800
# Maximum size of a single downloaded asset in bytes (example: 52428800 = 50MB)

MAX_PAGE_SIZE_MB=50
# Maximum total size of all downloaded assets per page in MB (example: 50 mb)

PLAYWRIGHT_BROWSERS_PATH=/app/playwright-browsers
# Path where Playwright installs Chromium (required in Docker)


############################################
# AI PROVIDERS — OpenAI & Anthropic
############################################

AI_PROVIDER=openai
# Active AI provider: openai | anthropic

OPENAI_API_KEY=your_openai_api_key_here
# OpenAI API key (stored in DB settings in-app, env optional fallback)

OPENAI_MODEL=gpt-4o-mini
# OpenAI model name (example: gpt-4o-mini)

ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Anthropic API key (stored in DB settings in-app, env optional fallback)

ANTHROPIC_MODEL=claude-3-haiku-20240307
# Anthropic model name (example: claude-3-haiku-20240307)

AI_REQUEST_TIMEOUT_SECONDS=30
# Timeout for a single AI API request in seconds (example: 30 s)

AI_BATCH_SIZE=20
# Number of text nodes per AI batch request (example: 20)

MAX_TOKENS_PER_BATCH=3000
# Maximum tokens per AI request batch (example: 3000 tokens)

REWRITE_FAIL_THRESHOLD=0.5
# Fraction of failed batches to mark job as failed (example: 0.5 = 50%)


############################################
# MEDIA PROCESSING — Image Uniqueization
############################################

NOISE_INTENSITY=0.01
# Gaussian noise intensity (float 0.0–0.01, example: 0.01)

SUPPORTED_IMAGE_FORMATS=.jpg,.jpeg,.png,.webp
# CSV list of supported image formats (example: .jpg,.png)


############################################
# FRONTEND — Build-Time (Next.js)
# IMPORTANT: These variables are embedded at build time.
############################################

NEXT_PUBLIC_API_URL=http://localhost:8000
# Public backend API URL (example for production: https://api.yourdomain.com)

NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Public WebSocket URL (example for production: wss://api.yourdomain.com)


############################################
# OPTIONAL — Future External Services
############################################

REDIS_URL=redis://localhost:6379/0
# Optional (Future): Redis for pub/sub or multi-worker mode (example: redis://localhost:6379/0)

SENTRY_DSN=your_sentry_dsn_here
# Optional: Sentry DSN for error monitoring (example: https://xxx.ingest.sentry.io/xxx)